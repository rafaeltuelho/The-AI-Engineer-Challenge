# AI Assistant App - Environment Configuration
# Copy this file to .env and configure the values

# ============================================
# Google OAuth Configuration
# ============================================

# Google OAuth Client ID (required for Google authentication)
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Comma-separated list of whitelisted email addresses (optional)
# If not set, all authenticated Google users are allowed
# WHITELISTED_EMAILS=user1@example.com,user2@example.com

# ============================================
# Free Tier Configuration
# ============================================

# Maximum number of free turns for guest/non-whitelisted users (default: 3)
MAX_FREE_TURNS=3

# Maximum tokens per message for free tier users (default: 500)
MAX_FREE_MESSAGE_TOKENS=500

# Provider to use for free tier (default: together)
FREE_PROVIDER=together

# Model to use for free tier (default: deepseek-ai/DeepSeek-V3.1)
FREE_MODEL=deepseek-ai/DeepSeek-V3.1

# ============================================
# API Keys (Optional - can be passed per-request)
# ============================================

# OpenAI API Key (optional - can be provided in request, required for free tier if FREE_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Together.ai API Key (optional - can be provided in request, required for free tier if FREE_PROVIDER=together)
# TOGETHER_API_KEY=your-together-api-key-here

# ============================================
# Session Management
# ============================================

# Session time-to-live in seconds (default: 86400 = 24 hours)
# Sessions inactive for this duration are expired and cleaned up on next access.
# SESSION_TTL_SECONDS=86400

# ============================================
# Conversation Context Management
# ============================================

# Compression threshold: fraction of model's context window at which older
# messages are summarized (default: 0.8 = 80%)
# CONTEXT_WINDOW_THRESHOLD_PCT=0.8

# Number of recent messages to keep uncompressed during summarization (default: 6)
# KEEP_RECENT_MESSAGES=6

# Maximum messages stored per conversation in Redis (default: 100)
# Oldest messages are trimmed first; summary messages are preserved.
# MAX_MESSAGES_PER_CONVERSATION=100

# ============================================
# Conversation Persistence (Optional - Upstash Redis)
# ============================================
# If set, Google-authenticated users' conversations persist across sessions.
# If not set, conversations are in-memory only (lost on server restart).
# Create a free database at https://console.upstash.com/

# UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

